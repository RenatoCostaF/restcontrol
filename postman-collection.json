  "item": [
    {
      "name": "POST Auth",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"login\":\"masteradmin\",\r\n    \"password\":\"mastadm123\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://{{domain}}/v1/auth/login",
          "protocol": "http",
          "host": [
            "{{domain}}"
          ],
          "path": [
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "exec": [
              "pm.test(\"Login retornou token\", function () {",
              "    pm.response.to.have.status(200);",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.token).to.be.a(\"string\").and.not.empty;",
              "    pm.collectionVariables.set(\"token\", \"Bearer \" + jsonData.token);",
              "});"
            ]
          }
        }
      ]
    },
